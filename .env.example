# ─── General ───────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
CLUSTERS_CONFIG=config/clusters.yaml
DEFAULT_CLUSTER=aks-prod

# Outward-facing notifications are OFF by default (security boundary).
ALLOW_NOTIFICATIONS=false
SLACK_ALLOWED_CHANNELS=#sre-incidents,#platform-alerts
TEAMS_ALLOWED_CHANNELS=

# ─── Observability backends (per-cluster overrides live in clusters.yaml) ────
PROMETHEUS_URL=http://prometheus.monitoring.svc:9090
LOKI_URL=http://loki.monitoring.svc:3100
GRAFANA_URL=http://grafana.monitoring.svc:3000
GRAFANA_TOKEN=

# ─── GitOps / CI ─────────────────────────────────────────────────────────────
ARGOCD_SERVER=https://argocd.example.com
ARGOCD_TOKEN=
GITLAB_URL=https://gitlab.example.com
GITLAB_TOKEN=
GITHUB_TOKEN=

# ─── Incident systems ─────────────────────────────────────────────────────────
JIRA_URL=https://example.atlassian.net
JIRA_EMAIL=
JIRA_TOKEN=
SERVICENOW_URL=https://example.service-now.com
SERVICENOW_USER=
SERVICENOW_PASSWORD=
SLACK_BOT_TOKEN=
TEAMS_WEBHOOK_URL=

# ─── RAG (pgvector) ───────────────────────────────────────────────────────────
RAG_ENABLED=false
PGVECTOR_DSN=postgresql://sre_agent:CHANGE_ME@pgvector.svc:5432/sre_kb
EMBEDDING_MODEL=voyage-3            # default (Voyage). For a no-API-key local model:
                                   #   EMBEDDING_MODEL=local:BAAI/bge-small-en-v1.5  (set EMBEDDING_DIM=384)
EMBEDDING_DIM=1024
# RAG tenant isolation (RLS) requires the agent's DB role to be NON-superuser and not the
# table owner (superusers/owners bypass RLS). Use a least-privilege role in PGVECTOR_DSN.

# ─── Auth (remote HTTP mode) ───────────────────────────────────────────────────
# OIDC / Entra ID validation for the streamable-HTTP transport.
OIDC_ISSUER=https://login.microsoftonline.com/<tenant-id>/v2.0
OIDC_AUDIENCE=api://k8s-sre-agent
OIDC_REQUIRED_GROUPS=sre-readonly,platform-oncall
